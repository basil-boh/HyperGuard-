# Frontend env (copy to .env.local). All optional for local dev:
# - /api/* is proxied to the backend via next.config rewrites.
# - the websocket defaults to ws://<host>:8000/ws/events.

# Point the API rewrite at a non-default backend:
# API_PROXY_TARGET=http://localhost:8000

# Or bypass the proxy and hit the backend directly:
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/events
