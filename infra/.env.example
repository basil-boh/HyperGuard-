# ─────────────────────────────────────────────────────────────────────────────
# HyperGuard environment
#
# Every credential below is OPTIONAL. With none set, the swarm runs end-to-end in
# a deterministic demo mode. Fill these in to light up live LLM dialogue,
# telephony, persistence, and the distributed event bus — no code changes needed.
# Copy this file to the repo root as `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
# Force the deterministic simulation even if keys are present (hermetic stage demo).
FORCE_DEMO_MODE=false

# ── Risk policy ───────────────────────────────────────────────────────────────
INTERVENTION_THRESHOLD=0.58
HARD_BLOCK_THRESHOLD=0.88
MAX_NEGOTIATION_TURNS=8
DEMO_STEP_DELAY=0.75

# ── LLM (Educator reasoning + Negotiator dialogue) ────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-5.5
LLM_TEMPERATURE=0.2

# ── Voice / telephony (Voice Negotiator + Guardian SMS) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Persistence (Supabase / Postgres) ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Distributed event bus (durability / replay) ───────────────────────────────
REDIS_URL=

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/events
